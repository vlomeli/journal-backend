PORT=3000
JWT_KEY=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*
DB_TIME_ZONE=-8:00

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Use one of these only if your database provider gives you a CA certificate.
# DB_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# DB_SSL_CA_PATH=/etc/secrets/db-ca.pem
